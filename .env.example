# SnapHood local config.
# Run on a Wrkr workstation:
#   wrkr db --json
#   wrkr cache --json
DATABASE_URL="postgresql://wrkr:password@127.0.0.1:5432/wrkr"
REDIS_URL="redis://127.0.0.1:6379"

# Public URL after `wrkr expose --port 3000 --name snaphood`.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth/session.
SNAPHOOD_SESSION_SECRET=""
SNAPHOOD_DEMO_AUTH_ENABLED="true"
SNAPHOOD_AUTH_EMAIL_MODE="dry-run"
SNAPHOOD_AUTH_EMAIL_FROM=""
SNAPHOOD_AUTH_MAGIC_LINK_TTL_MINUTES="15"
SNAPHOOD_ADMIN_EMAILS=""
SNAPHOOD_MAINTENANCE_DRY_RUN="true"
SNAPHOOD_AUTH_CHALLENGE_RETENTION_DAYS="7"
SNAPHOOD_STALE_DRAFT_RETENTION_DAYS="30"

# AI. OpenAI-compatible chat/vision endpoint; image generation is optional for MVP.
LLM_PROVIDER="openai"
LLM_BASE_URL="https://api.openai.com/v1"
LLM_MODEL="gpt-5.6-luna"
LLM_API_KEY=""
IMAGE_MODEL="fal-ai/flux/schnell"
FAL_KEY=""
FAL_IMAGE_MODEL="fal-ai/flux/schnell"

# Storage. When disabled, uploads are saved under public/uploads for local demo.
# Public Wrkr storage URLs require object keys under public/...; the app handles this when public uploads are enabled.
WRKR_STORAGE_ENABLED="false"
WRKR_STORAGE_PUBLIC_UPLOADS="false"

# Robinhood Chain.
ROBINHOOD_NETWORK="testnet"
ROBINHOOD_RPC_URL="https://rpc.testnet.chain.robinhood.com"
ROBINHOOD_CHAIN_ID="46630"
ROBINHOOD_BLOCK_EXPLORER_URL="https://explorer.testnet.chain.robinhood.com"
ALCHEMY_API_KEY=""
DEPLOYER_PRIVATE_KEY=""
DEPLOYER_ADDRESS=""

# Launch behavior.
TOKEN_LAUNCH_MODE="demo"
DEFAULT_TOKEN_SUPPLY="1000000000"
DEFAULT_TOKEN_DECIMALS="18"

# Optional trading/liquidity setup for Robinhood Chain mainnet Uniswap v3.
# Keep these blank until you intentionally seed a pool.
TRADING_TOKEN_ADDRESS=""
TRADING_POOL_ADDRESS=""
TRADING_POSITION_ID=""
ROBINHOOD_WETH_ADDRESS="0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73"
UNISWAP_V3_FACTORY="0x1f7d7550b1b028f7571e69a784071f0205fd2efa"
UNISWAP_V3_POSITION_MANAGER="0x73991a25c818bf1f1128deaab1492d45638de0d3"
UNISWAP_V3_SWAP_ROUTER_02="0xcaf681a66d020601342297493863e78c959e5cb2"
UNISWAP_UNIVERSAL_ROUTER="0x8876789976decbfcbbbe364623c63652db8c0904"
UNISWAP_V3_FEE="10000"
LIQUIDITY_TOKEN_AMOUNT="1000000"
LIQUIDITY_ETH_AMOUNT="0.0001"
LIQUIDITY_DRY_RUN="true"
SWAP_ETH_AMOUNT="0.00001"
SWAP_DRY_RUN="true"
